{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "flowquest",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const fs=require('fs'),path=require('path'),u=q.url==='/'?'/index.html':q.url,f=path.join('.',u),ext=path.extname(f),types={'.html':'text/html','.css':'text/css','.js':'application/javascript','.png':'image/png','.jpg':'image/jpeg','.svg':'image/svg+xml','.ico':'image/x-icon','.woff2':'font/woff2','.json':'application/json'};fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':types[ext]||'application/octet-stream'});r.end(d)}})}).listen(3000)"],
      "port": 3000
    }
  ]
}
